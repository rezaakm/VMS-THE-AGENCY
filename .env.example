# ============================================
# The Agency VMS — Environment Variables
# ============================================
# Copy this file to packages/backend/.env and fill in values.
# Never commit the actual .env file.

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vms_db"

# Authentication
JWT_SECRET="your-secure-jwt-secret-here"

# Server
PORT=3001

# Frontend URL (for CORS and links)
FRONTEND_URL="http://localhost:3000"

# API URL (used by frontend)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# OpenAI (optional — for Cost Engine AI features)
# OPENAI_API_KEY="sk-..."

# Email Notifications (planned — Phase 4)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_FROM_EMAIL=

# Zoho Books Integration (planned — Phase 4)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_ORGANIZATION_ID=

# ============================================
# Google Drive — Cost Sheets & Historical Data
# ============================================
# Used for syncing detailed cost sheets (including your Cost Sheet-Master archive from 2023+)
# You already went through OAuth multiple times with Cursor.
# You can reuse the same Google Cloud OAuth credentials.

# Your Google OAuth Client ID
GOOGLE_CLIENT_ID="508721497578-8t2eq7iqsl3tagcarhih57odkgspjt8b.apps.googleusercontent.com"

# Your Google OAuth Client Secret (the one you just shared)
GOOGLE_CLIENT_SECRET="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"

# GOOGLE_REFRESH_TOKEN=          # Reuse a refresh token from previous Cursor auths if still valid

# Your main Cost Sheet-Master folder on Drive
# https://drive.google.com/drive/folders/1uDCJBOZARhEiBrOEdG3QP2Cm0GrNI-2I
GOOGLE_DRIVE_FOLDER_ID="1uDCJBOZARhEiBrOEdG3QP2Cm0GrNI-2I"

# Notes:
# - All secrets must stay in .env, never in code or version control.
# - For office network access: set FRONTEND_URL and NEXT_PUBLIC_API_URL to the server PC's IP.
# - For Docker: see docker-compose.yml for environment variable injection.
# - After adding GOOGLE_REFRESH_TOKEN, restart the backend.
# - You can test the connection with: GET /cost-sheets/drive/status
