# ============================================
# The Agency VMS — Environment Variables
# ============================================
# Copy this file to packages/backend/.env and fill in values.
# Never commit the actual .env file.

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vms_db"

# Authentication
JWT_SECRET="your-secure-jwt-secret-here"

# Server
PORT=3001

# Frontend URL (for CORS and links)
FRONTEND_URL="http://localhost:3000"

# API URL (used by frontend)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# OpenAI (optional — for Cost Engine AI features)
# OPENAI_API_KEY="sk-..."

# Google Drive (catalog files from assigned folder into database)
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_REDIRECT_URI=http://localhost:3001/google-drive/auth/callback

# Email Notifications (planned — Phase 4)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_FROM_EMAIL=

# Zoho Books Integration (Settings → Zoho Books, admin)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_DATA_CENTER=com
# ZOHO_DATA_CENTER=sa
# ZOHO_REDIRECT_URI=http://localhost:3001/zoho/auth/callback
# BACKEND_URL=http://localhost:3001
# ZOHO_ORGANIZATION_ID=
# ZOHO_REFRESH_TOKEN=

# Notes:
# - All secrets must stay in .env, never in code or version control.
# - For office network access: set FRONTEND_URL and NEXT_PUBLIC_API_URL to the server PC's IP.
# - For Docker: see docker-compose.yml for environment variable injection.
