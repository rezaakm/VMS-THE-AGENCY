# Frontend (Vite) Environment
# The API base URL the generated client will call
VITE_API_URL=http://localhost:3001/api

# For local dev only - the Ready folder was extracted from Replit
# These provide sensible defaults so you don't have to set them
PORT=5173
BASE_PATH=/

# If you deploy the frontend, set VITE_API_URL to your deployed api-server URL (https://your-api.railway.app/api)