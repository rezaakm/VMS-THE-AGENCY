// Add at the end of the schema, after the Financial Oversight models

// === Finance Data Ingestion ===

enum FinancialDocumentType {
  MONTHLY_FINANCE_PACK
  BANK_STATEMENT
  INVOICE_PACK
  AUDIT_REPORT
  GENERAL_EXCEL
  PDF_REPORT
}

model FinancialDocument {
  id            String                @id @default(uuid())
  type          FinancialDocumentType
  period        String?               // e.g. "2026-04"
  originalName  String
  mimeType      String?
  size          Int?
  storagePath   String?               // local path or S3 key
  extractedData Json?                 // Raw structured data extracted from the file
  status        String                @default("UPLOADED") // UPLOADED, PROCESSING, COMPLETED, FAILED
  processedAt   DateTime?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // Link to what it created
  createdFlags  FinancialFlag[]
  // We can add more relations later (created invoices, etc.)

  @@map("financial_documents")
}
