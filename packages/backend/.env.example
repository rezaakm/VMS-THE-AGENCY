DATABASE_URL="postgresql://vms_user:vms_password@localhost:5432/vms_db"
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRATION="7d"
PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV=development

# Optional - for AI-powered cost analysis features
# OPENAI_API_KEY="sk-..."

# Google Drive Sync (auto-syncs cost sheets every hour)
# GOOGLE_DRIVE_FOLDER_ID="your-drive-folder-id"
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# GOOGLE_REFRESH_TOKEN="obtained-after-oauth-flow"

# SMTP (RFQ invites + financial oversight alerts)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=VMS <noreply@theagency.om>
# Comma-separated finance/manager inboxes for flag deadline alerts
# FINANCIAL_ALERT_EMAILS=finance@theagency.om,reza@theagency.om

# Zoho Books (admin: Settings → connect; Oman often uses data center sa)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_DATA_CENTER=sa
# ZOHO_REDIRECT_URI=http://localhost:3001/zoho/auth/callback
# BACKEND_URL=http://localhost:3001
# ZOHO_ORGANIZATION_ID=
# ZOHO_REFRESH_TOKEN=
